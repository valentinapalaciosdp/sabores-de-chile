              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align:center;\">La reina de las Fiestas Patrias: carne, cebolla, huevo, aceituna y una pasita. Crujiente por fuera y jugosa por dentro.</p>"
